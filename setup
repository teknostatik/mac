#!/usr/bin/env bash

# This script sets up a new Mac with the applications I use regularly and occasionally.
# It is interactive and groups software by theme so related tools are easier to choose.

is_yes() {
    case "$1" in
        y|Y|yes|Yes|YES)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

prompt_yes_no() {
    local prompt="$1"
    local response

    echo "$prompt (y/N)"
    read -r response
    is_yes "$response"
}

append_alias_once() {
    local alias_line="$1"
    local shell_rc="$HOME/.zshrc"

    touch "$shell_rc"
    if ! grep -Fqx "$alias_line" "$shell_rc"; then
        echo "$alias_line" >> "$shell_rc"
        echo "Alias added: $alias_line"
        echo "Restart your terminal or run 'source ~/.zshrc' to activate it."
    else
        echo "Alias already present in ~/.zshrc, skipping..."
    fi
}

ensure_rosetta() {
    if [ "$(uname -m)" != "arm64" ]; then
        return 0
    fi

    echo "Apple Silicon detected. Checking for Rosetta..."
    if ! /usr/bin/pgrep -q oahd; then
        echo "Installing Rosetta 2..."
        /usr/sbin/softwareupdate --install-rosetta --agree-to-license
    else
        echo "Rosetta 2 is already installed."
    fi
}

ensure_brew_tap() {
    local tap_name="$1"

    if ! brew tap | grep -qx "$tap_name"; then
        echo "Adding Homebrew tap: $tap_name"
        brew tap "$tap_name"
    fi
}

ensure_homebrew() {
    if ! command -v brew >/dev/null 2>&1; then
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi

    if [ -x /opt/homebrew/bin/brew ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [ -x /usr/local/bin/brew ]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi
}

is_installed() {
    local kind="$1"
    local package_name="$2"

    case "$kind" in
        cask)
            brew list --cask "$package_name" >/dev/null 2>&1
            ;;
        formula)
            brew list "$package_name" >/dev/null 2>&1
            ;;
        *)
            return 1
            ;;
    esac
}

install_package() {
    local kind="$1"
    local package_name="$2"

    case "$kind" in
        cask)
            brew install --cask "$package_name"
            ;;
        formula)
            brew install "$package_name"
            ;;
    esac
}

is_bundle_installed() {
    local key="$1"

    case "$key" in
        qmk)
            is_installed formula qmk/qmk/qmk && is_installed cask qmk-toolbox
            ;;
        *)
            return 1
            ;;
    esac
}

run_hook() {
    local hook_name="$1"

    case "$hook_name" in
        none)
            ;;
        alias_top_htop)
            if prompt_yes_no "Would you like to alias 'top' to 'htop'?"; then
                append_alias_once "alias top='htop'"
            fi
            ;;
        alias_ls_eza)
            if prompt_yes_no "Would you like to alias 'ls' to 'eza -l'?"; then
                append_alias_once "alias ls='eza -l'"
            fi
            ;;
        dropbox_dash)
            if ! is_installed cask dropbox-dash && prompt_yes_no "Also install Dropbox Dash? (AI-powered search)"; then
                brew install --cask dropbox-dash
            fi
            ;;
        ensure_rosetta)
            ensure_rosetta
            ;;
        lm_studio_launch)
            if prompt_yes_no "Launch LM Studio now?"; then
                open -a "LM Studio"
            fi
            ;;
        displaylink_launch)
            if prompt_yes_no "Launch DisplayLink Manager now to grant permissions?"; then
                open -a "DisplayLink Manager"
                echo "Note: Grant Screen Recording and Accessibility permissions in System Settings > Privacy & Security."
            fi
            ;;
        hrm_note)
            echo "Note: Launch HRM and grant Accessibility permission in System Settings > Privacy & Security > Accessibility."
            ;;
        ollama_setup)
            if prompt_yes_no "Start Ollama as a background service now?"; then
                brew services start ollama
                echo "Ollama service started."
                if prompt_yes_no "Download a starter model (llama3)?"; then
                    ollama pull llama3
                fi
            else
                echo "You can start it later with: brew services start ollama"
            fi
            ;;
        qmk_bundle)
            if ! is_installed formula qmk/qmk/qmk; then
                brew install qmk/qmk/qmk
            else
                echo "QMK CLI is already installed, skipping..."
            fi
            if ! is_installed cask qmk-toolbox; then
                brew install --cask qmk-toolbox
            else
                echo "QMK Toolbox is already installed, skipping..."
            fi
            qmk setup
            ;;
        deskflow_tap)
            ensure_brew_tap "deskflow/homebrew-tap"
            ;;
        hrm_tap)
            ensure_brew_tap "wontaeyang/hrm"
            ;;
    esac
}

install_entry() {
    local entry="$1"
    local key theme_id app_name kind package_name description pre_hook post_hook

    IFS='|' read -r key theme_id app_name kind package_name description pre_hook post_hook <<< "$entry"

    if [ "$kind" = "bundle" ]; then
        if is_bundle_installed "$key"; then
            echo "$app_name is already installed, skipping..."
            return 0
        fi

        echo ""
        if prompt_yes_no "Install $app_name? ($description)"; then
            run_hook "$post_hook"
        fi
        return 0
    fi

    if is_installed "$kind" "$package_name"; then
        echo "$app_name is already installed, skipping..."
        return 0
    fi

    echo ""
    if ! prompt_yes_no "Install $app_name? ($description)"; then
        return 0
    fi

    if [ "$pre_hook" != "none" ]; then
        run_hook "$pre_hook"
    fi

    install_package "$kind" "$package_name"

    if [ "$post_hook" != "none" ]; then
        run_hook "$post_hook"
    fi
}

review_theme() {
    local theme_id="$1"
    local theme_name="$2"
    local theme_summary="$3"
    local entry

    echo ""
    echo "-------------------------------------------------------------------------"
    echo "$theme_name"
    echo "$theme_summary"
    echo "-------------------------------------------------------------------------"

    for entry in "${APPS[@]}"; do
        IFS='|' read -r _ entry_theme _ _ _ _ _ _ <<< "$entry"
        if [ "$entry_theme" = "$theme_id" ]; then
            install_entry "$entry"
        fi
    done
}

THEMES=(
    "browsers|Browsers|Web browsers and browser alternatives."
    "development|Development|Editors, runtimes, and developer-focused tools."
    "terminal|Terminal Tools|CLI utilities, terminal environments, and shell enhancements."
    "cloud|Cloud and Sync|Storage, sync, and remote access tools."
    "security|Security and Privacy|VPN and password management tools."
    "media|Media and Creative|Audio, video, image, ebook, and media tools."
    "communication|Communication|Meeting, chat, and collaboration apps."
    "virtualization|Virtualization|Virtual machines and containers."
    "ai|AI Tools|Local model runtimes and interfaces."
    "keyboards|Keyboards and Input|Keyboard firmware, remapping, and input utilities."
    "utilities|Utilities|General desktop utilities and reference tools."
)

APPS=(
    "firefox|browsers|Firefox|cask|firefox|web browser|none|none"
    "chrome|browsers|Google Chrome|cask|google-chrome|web browser|none|none"
    "ungoogled|browsers|Ungoogled Chromium|cask|ungoogled-chromium|privacy-focused browser|none|none"
    "vscode|development|Visual Studio Code|cask|visual-studio-code|code editor and IDE|none|none"
    "node|development|Node.js|formula|node|JavaScript runtime|none|none"
    "gh|terminal|GitHub CLI|formula|gh|gh command line tool|none|none"
    "fastfetch|terminal|fastfetch|formula|fastfetch|system information tool|none|none"
    "byobu|terminal|byobu|formula|byobu|terminal multiplexer|none|none"
    "htop|terminal|htop|formula|htop|system monitor|none|alias_top_htop"
    "iterm2|terminal|iTerm2|cask|iterm2|terminal emulator|none|none"
    "ripgrep|terminal|ripgrep|formula|ripgrep|fast text search tool|none|none"
    "eza|terminal|eza|formula|eza|modern ls replacement|none|alias_ls_eza"
    "tldr|terminal|tldr|formula|tldr|simplified command-line documentation|none|none"
    "dropbox|cloud|Dropbox|cask|dropbox|cloud storage|none|dropbox_dash"
    "protondrive|cloud|Proton Drive|cask|proton-drive|secure cloud storage|none|none"
    "zerotier|cloud|ZeroTier One|cask|zerotier-one|network virtualization|none|none"
    "protonvpn|security|ProtonVPN|cask|protonvpn|VPN service|none|none"
    "protonpass|security|Proton Pass|cask|proton-pass|password manager|none|none"
    "container|virtualization|Container|cask|container|app sandboxing|none|none"
    "spotify|media|Spotify|cask|spotify|music streaming|none|none"
    "vlc|media|VLC|cask|vlc|media player|none|none"
    "imagemagick|media|ImageMagick|formula|imagemagick|image manipulation tool|none|none"
    "pandoc|utilities|Pandoc|formula|pandoc|document converter|none|none"
    "gimp|media|GIMP|cask|gimp|image editor|none|none"
    "audacity|media|Audacity|cask|audacity|audio editor|none|none"
    "handbrake|media|HandBrake|cask|handbrake|video transcoder|none|none"
    "calibre|media|Calibre|cask|calibre|ebook manager|none|none"
    "lastfm|media|Last.fm|cask|lastfm|music scrobbling|ensure_rosetta|none"
    "bandcampdl|media|bandcamp-dl|formula|bandcamp-dl|Bandcamp music downloader|none|none"
    "transmission|media|Transmission|cask|transmission|BitTorrent client|none|none"
    "zoom|communication|Zoom|cask|zoom|video conferencing|none|none"
    "teams|communication|Microsoft Teams|cask|microsoft-teams|team collaboration|none|none"
    "whatsapp|communication|WhatsApp|cask|whatsapp|messaging app|none|none"
    "multipass|virtualization|Multipass|cask|multipass|Ubuntu VM manager|none|none"
    "utm|virtualization|UTM|cask|utm|virtual machine host|none|none"
    "macpine|virtualization|macpine|formula|macpine|lightweight Alpine Linux VM|none|none"
    "rpi|utilities|Raspberry Pi Imager|cask|raspberry-pi-imager|SD card imaging tool for Raspberry Pi|none|none"
    "displaylink|utilities|DisplayLink Manager|cask|displaylink|USB display drivers|none|displaylink_launch"
    "ollama|ai|Ollama|formula|ollama|local LLM runtime|none|ollama_setup"
    "lmstudio|ai|LM Studio|cask|lm-studio|local AI model UI|none|lm_studio_launch"
    "vial|keyboards|Vial|cask|vial|keyboard configuration tool|ensure_rosetta|none"
    "via|keyboards|VIA|cask|via|keyboard remapping tool|ensure_rosetta|none"
    "qmk|keyboards|QMK and QMK Toolbox|bundle|qmk-bundle|keyboard firmware development|none|qmk_bundle"
    "hrm|keyboards|HRM|cask|hrm|home row mods menu bar app|hrm_tap|hrm_note"
    "deskflow|utilities|Deskflow|cask|deskflow|keyboard and mouse sharing|deskflow_tap|none"
    "caffeine|utilities|Caffeine|cask|caffeine|prevent display sleep, menu bar app|none|none"
    "muzzle|utilities|Muzzle|cask|muzzle|automatically mutes notifications while sharing your screen|none|none"
    "burn|utilities|Burn|cask|burn|CD and DVD burning application|none|none"
    "mactracker|utilities|MacTracker|cask|mactracker|Apple device specifications|none|none"
)

echo "    ========================================================================="
echo "    ███╗   ███╗ █████╗  ██████╗    ███████╗███████╗████████╗██╗   ██╗██████╗ "
echo "    ████╗ ████║██╔══██╗██╔════╝    ██╔════╝██╔════╝╚══██╔══╝██║   ██║██╔══██╗"
echo "    ██╔████╔██║███████║██║         ███████╗█████╗     ██║   ██║   ██║██████╔╝"
echo "    ██║╚██╔╝██║██╔══██║██║         ╚════██║██╔══╝     ██║   ██║   ██║██╔═══╝ "
echo "    ██║ ╚═╝ ██║██║  ██║╚██████╗    ███████║███████╗   ██║   ╚██████╔╝██║     "
echo "    ╚═╝     ╚═╝╚═╝  ╚═╝ ╚═════╝    ╚══════╝╚══════╝   ╚═╝    ╚═════╝ ╚═╝     "
echo "    ========================================================================="
echo ""
echo "    Welcome to the Mac Setup Script!"
echo ""
echo "    This interactive script helps you set up a new Mac with Homebrew."
echo "    Software is grouped by theme so you can review related tools together,"
echo "    such as browsers, terminal tools, media apps, AI tools, or keyboard tooling."
echo ""
echo "    What this script does:"
echo "    • Installs Homebrew (if not already present)"
echo "    • Lets you review software by theme"
echo "    • Prompts for each app individually within the themes you choose"
echo "    • Reuses existing install hooks for aliases, Rosetta, taps, and services"
echo "    • Skips packages that are already installed"
echo ""
echo "    Press Enter to continue, or Ctrl+C to exit..."
read -r

ensure_homebrew

echo ""
echo "Choose which themes you want to review."
echo "If you skip a theme, none of its apps will be prompted."

for theme in "${THEMES[@]}"; do
    IFS='|' read -r theme_id theme_name theme_summary <<< "$theme"
    echo ""
    if prompt_yes_no "Review $theme_name?"; then
        review_theme "$theme_id" "$theme_name" "$theme_summary"
    fi
done

echo ""
echo "Setup complete!"
